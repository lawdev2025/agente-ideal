# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_DRY_RUN=0

# LLM Provider — "claude" (recommended) or "gemini"
LLM_PROVIDER=claude

# Anthropic Claude (default — get key at console.anthropic.com)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Gemini (fallback)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Telegram (handoff)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Persona e instituição
INSTITUTION_NAME=
PERSONA_NAME=Ana
ENROLLMENT_PERIOD_END=2026-12-15

# Operacional
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
DB_PATH=./data/agente.db
ADMIN_TOKEN=
