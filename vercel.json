{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/app", "destination": "/app/index.html" },
    { "source": "/webhook", "destination": "/api/webhook" }
  ],
  "redirects": [
    { "source": "/", "destination": "/admin", "permanent": false }
  ],
  "functions": {
    "api/webhook.ts": { "maxDuration": 30 },
    "api/jobs/classify-topics.ts": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/jobs/classify-topics", "schedule": "0 3 * * *" }
  ],
  "headers": [
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/app/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/app/" }
      ]
    },
    {
      "source": "/app/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ]
}
